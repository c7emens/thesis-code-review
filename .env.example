# OpenSky Network credentials (research account)
# Register at https://opensky-network.org/index.php?option=com_users
#
# WARNING: do not commit the filled-in .env to git. OpenSky accounts are
# per-individual under their Terms of Service, and credentials published to
# a public repo are harvested by automated scrapers within hours. .gitignore
# excludes .env by default — keep that rule in place.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Optional: override default data lake root (defaults to /mnt/e/data_lake)
# DATA_LAKE_ROOT=/path/to/data_lake

# Database connection (matches docker-compose.yml defaults; usually leave unset)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=windfarm
# DB_USER=thesis
# DB_PASSWORD=thesis2026
